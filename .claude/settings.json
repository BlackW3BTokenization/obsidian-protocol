{
  "permissions": {
    "allow": [
      "Bash(npm install)",
      "Bash(npm run *)",
      "Bash(anchor *)",
      "Bash(cargo *)",
      "Bash(surfpool *)",
      "Bash(solana *)",
      "Bash(git *)"
    ]
  },
  "mcpServers": {
    "helius": {
      "command": "npx",
      "args": ["-y", "@helius-labs/helius-mcp"],
      "env": {
        "HELIUS_API_KEY": "SET_YOUR_KEY_HERE"
      }
    },
    "phantom-wallet": {
      "command": "npx",
      "args": ["-y", "phantom-mcp-server"]
    },
    "blender": {
      "command": "uvx",
      "args": ["blender-mcp"]
    }
  }
}
